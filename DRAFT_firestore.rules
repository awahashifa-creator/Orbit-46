rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'nisn', 'className', 'grade', 'attendance', 'category', 'attitude', 'status'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.nisn is string && data.nisn.size() > 0 && data.nisn.size() <= 20
        && data.className is string && data.className.size() > 0 && data.className.size() <= 50
        && data.grade is number
        && data.attendance is number
        && data.category is string && (data.category == 'Kelulusan' || data.category == 'Kenaikan')
        && data.attitude is string && data.attitude.size() <= 20
        && data.status is string && data.status.size() <= 20
        && (!data.keys().hasAny(['createdBy']) || (data.createdBy is string && data.createdBy.size() <= 100));
    }

    match /students/{studentId} {
      // Allow read to everyone so they can check kelulusan without login
      allow read: if true;
      allow list: if true;
      
      allow create: if isSignedIn() 
                    && isValidId(studentId)
                    && isValidStudent(incoming());
                    
      allow update: if isSignedIn()
                    && isValidStudent(incoming());
                    
      allow delete: if isSignedIn();
    }
  }
}
